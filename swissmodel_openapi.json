, "readOnly": true}, "status": {"title": "Status", "type": "string", "readOnly": true}, "date_created": {"title": "Date created", "type": "string", "readOnly": true}, "project_title": {"title": "Project title", "type": "string", "readOnly": true}, "project_type": {"title": "Project type", "type": "string", "readOnly": true}, "model_count": {"title": "Model count", "type": "string", "readOnly": true}}}, "Download Projects": {"type": "object", "properties": {"coordinates_type": {"title": "Coordinates type", "type": "string", "enum": ["pdb", "cif"]}, "from_datetime": {"title": "From datetime", "description": "Download projects created after from_datetime,  Must be in isoformat, eg \"2024-09-20T10:05:20\" ", "type": "string", "maxLength": 19, "minLength": 1, "x-nullable": true}, "to_datetime": {"title": "To datetime", "description": "Download projects created before to_datetime,  Must be in isoformat, eg \"2024-09-22T12:12:20\" ", "type": "string", "maxLength": 19, "minLength": 1, "x-nullable": true}, "download_id": {"title": "Download id", "type": "string", "readOnly": true, "minLength": 1}}}, "Download Projects Results": {"type": "object", "properties": {"status": {"title": "Status", "type": "string", "enum": ["INITIALISED", "QUEUEING", "RUNNING", "COMPLETED", "FAILED", "UNKNOWN"], "readOnly": true}, "coordinates_type": {"title": "Coordinates type", "type": "string", "enum": ["pdb", "cif"], "readOnly": true}, "from_datetime": {"title": "From datetime", "description": "Download projects created after from_datetime,  Must be in isoformat, eg \"2024-09-20T10:05:20\" ", "type": "string", "readOnly": true, "minLength": 1, "x-nullable": true}, "to_datetime": {"title": "To datetime", "description": "Download projects created before to_datetime,  Must be in isoformat, eg \"2024-09-22T12:12:20\" ", "type": "string", "readOnly": true, "minLength": 1, "x-nullable": true}, "download_id": {"title": "Download id", "type": "string", "readOnly": true, "minLength": 1}, "download_url":